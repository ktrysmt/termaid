{
  "name": "memd-cli",
  "version": "3.5.2",
  "type": "module",
  "main": "main.js",
  "bin": {
    "memd": "main.js"
  },
  "scripts": {
    "test": "vitest run --maxConcurrency=20"
  },
  "dependencies": {
    "@ktrysmt/beautiful-mermaid": "1.4.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "marked": "^17.0.4",
    "marked-terminal": "^7.3.0",
    "shiki": "^4.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ktrysmt/memd.git"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "tuistory": "^0.0.16",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "marked-terminal": {
      "marked": "$marked"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "marked-terminal>marked": ">=17"
      }
    }
  }
}
